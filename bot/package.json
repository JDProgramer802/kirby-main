{
  "name": "whatsapp-group-bot",
  "version": "1.0.0",
  "description": "Bot de WhatsApp para grupos (Baileys)",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "index.js",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first node index.js",
    "keepalive": "node scripts/keepalive.js",
    "setup": "node scripts/setup.js",
    "web": "node web/server.js",
    "check": "node --check index.js && node --check web/server.js && node --check database/db.js && node --check core/subbot.js && node --check utils/youtubeAgent.js && node --check database/panelConfig.js"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.14.4",
    "@itsukichan/baileys": "^7.3.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "pino": "^9.4.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.5",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
