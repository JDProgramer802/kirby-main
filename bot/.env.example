# Copia a .env: cp .env.example .env

BOT_PREFIX=/
BOT_OWNER=521234567890@s.whatsapp.net
BOT_NAME=WhatsApp Bot
SESSION_DIR=./sessions/main

# Panel web (npm run web)
WEB_PORT=3000
JWT_SECRET=cambia-esto-en-produccion-minimo-32-caracteres

# Supabase (recomendado): Project Settings → Database → Connection string → URI
# Incluye ?sslmode=require. Para Node suele usarse el pooler (puerto 6543) en producción.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Alternativa sin URL (PostgreSQL local u otro host):
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=postgres
# DB_SSL=false

# YouTube: archivo Netscape (Export cookies / yt-dlp). Evita "Sign in to confirm you're not a bot".
# Por defecto: ./cookies.txt en la carpeta del bot. Opcional: ruta absoluta o relativa al bot.
# YT_COOKIES_PATH=./cookies.txt

GITHUB_TOKEN=
GITHUB_REPO=JDProgramer802/kirby-main
GITHUB_BRANCH=main

# Varias instancias (cada una con sesión y prefijo propios):
# SUBBOTS=[{"id":"main","name":"Bot A","prefix":"/","sessionDir":"./sessions/main"},{"id":"b2","prefix":"!","sessionDir":"./sessions/b2"}]
